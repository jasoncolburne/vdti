    {
      "id": "FqpdRaPnnlo62J2KmrSGv",
      "type": "text",
      "x": 1600.6537030435493,
      "y": 4661.14782277417,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
