# verbs "issues" / "revokes" / "rescinds" stay live, so forbid only the
# role-access (`manifest.<role>`) and the inline-list (`<role>[]`) spellings.
manifest\.issues
manifest\.revokes
manifest\.rescinds
issues\[\]
revokes\[\]
rescinds\[\]
